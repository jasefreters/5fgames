<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Rugby League Bull Rush</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #000; overflow: hidden; font-family: sans-serif; }
    #mount { width: 100vw; height: 100vh; }
    #hud { position: absolute; top: 12px; left: 0; right: 0; display: flex; justify-content: space-between; padding: 0 16px; pointer-events: none; display: none; }
    #hud-left, #hud-right { background: rgba(0,0,0,0.6); color: #fff; padding: 6px 14px; border-radius: 8px; font-size: 15px; }
    #controls-hint { position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.5); color: #ccc; padding: 5px 14px; border-radius: 8px; font-size: 12px; pointer-events: none; display: none; }
    #flash { position: absolute; top: 40%; left: 50%; transform: translate(-50%,-50%); font-size: 42px; font-weight: bold; text-shadow: 0 0 20px rgba(0,0,0,0.8); pointer-events: none; display: none; }
    #overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; }
    #overlay.hidden { display: none; }
    .ov-title { font-size: 48px; font-weight: bold; color: #00ff88; text-shadow: 0 0 20px #00ff88; }
    .ov-sub { font-size: 18px; color: #aaa; margin: 8px 0 28px; }
    .ov-info { color: #ccc; font-size: 14px; margin-bottom: 28px; text-align: center; line-height: 1.8; }
    .ov-score { font-size: 56px; font-weight: bold; color: #00ff88; }
    .ov-round { color: #aaa; margin: 6px 0 24px; }
    .ov-btn { padding: 14px 40px; font-size: 20px; font-weight: bold; background: #00ff88; color: #002b5c; border: none; border-radius: 10px; cursor: pointer; }
    .ov-btn:hover { background: #00e87a; }
    #gameover-title { font-size: 44px; font-weight: bold; color: #ff4444; }
  </style>
</head>
<body>
  <div id="mount"></div>
  <div id="hud">
    <div id="hud-left"></div>
    <div id="hud-right"></div>
  </div>
  <div id="controls-hint">WASD / Arrow Keys to move &nbsp;|&nbsp; Hold mouse drag to look around</div>
  <div id="flash"></div>

  <!-- Title Screen -->
  <div id="overlay" style="background:rgba(0,20,0,0.82);">
    <div class="ov-title">🏉 BULL RUSH</div>
    <div class="ov-sub">Rugby League Edition</div>
    <div class="ov-info">
      Run through the defenders to score a try!<br/>
      <b>WASD</b> or <b>Arrow Keys</b> to move<br/>
      <b>Hold + drag mouse</b> to look around<br/>
      3 tackles and you're out
    </div>
    <button class="ov-btn" id="start-btn">KICK OFF</button>
  </div>

  <!-- Game Over Screen -->
  <div id="gameover" class="hidden" style="position:absolute;inset:0;background:rgba(0,0,0,0.85);display:none;flex-direction:column;align-items:center;justify-content:center;color:#fff;">
    <div id="gameover-title">FULL TIME</div>
    <div style="font-size:22px;margin:12px 0 6px;">Final Score</div>
    <div class="ov-score" id="final-score">0</div>
    <div class="ov-round" id="final-round"></div>
    <button class="ov-btn" id="replay-btn">PLAY AGAIN</button>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="game.js"></script>
</body>
</html>
